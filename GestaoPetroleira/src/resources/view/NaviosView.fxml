<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.NavioController"
      spacing="10" style="-fx-padding: 15;">

    <Label text="Gestão de Navios" style="-fx-font-size: 18; -fx-font-weight: bold;"/>

    <TableView fx:id="tabelaNavios" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId"     text="ID"       prefWidth="50"/>
            <TableColumn fx:id="colNome"   text="Nome"     prefWidth="180"/>
            <TableColumn fx:id="colImo"    text="Cód. IMO" prefWidth="120"/>
            <TableColumn fx:id="colTipo"   text="Tipo"     prefWidth="140"/>
            <TableColumn fx:id="colEstado" text="Estado"   prefWidth="130"/>
        </columns>
    </TableView>

    <GridPane hgap="10" vgap="8">
        <Label text="Nome:"      GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="txtNome" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="220"/>

        <Label text="Cód. IMO:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="txtImo"  GridPane.columnIndex="1" GridPane.rowIndex="1"/>

        <Label text="Tipo:"     GridPane.columnIndex="2" GridPane.rowIndex="0"/>
        <ComboBox fx:id="cmbTipo"   GridPane.columnIndex="3" GridPane.rowIndex="0" prefWidth="160"/>

        <Label text="Estado:"   GridPane.columnIndex="2" GridPane.rowIndex="1"/>
        <ComboBox fx:id="cmbEstado" GridPane.columnIndex="3" GridPane.rowIndex="1" prefWidth="160"/>
    </GridPane>

    <HBox spacing="10">
        <Button text="Adicionar"   onAction="#onAdicionar"/>
        <Button text="Editar"      onAction="#onEditar"/>
        <Button text="Eliminar"    onAction="#onEliminar"/>
        <Button text="Manutenções" onAction="#onManutencoes"/>
        <Button text="Tripulação"  onAction="#onTripulacao"/>
    </HBox>

</VBox>