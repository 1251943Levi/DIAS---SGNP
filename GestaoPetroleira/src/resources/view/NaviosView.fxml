<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.NavioController">
  <top>
    <Label text="Gestão de Navios" style="-fx-font-size:18;-fx-padding:10;"/>
  </top>

  <center>
    <TableView fx:id="tabelaNavios" onMouseClicked="#onSelecionar">
      <columns>
        <TableColumn fx:id="colId"            text="ID"            prefWidth="40"/>
        <TableColumn fx:id="colNome"          text="Nome"          prefWidth="140"/>
        <TableColumn fx:id="colImo"           text="Cód. IMO"      prefWidth="110"/>
        <TableColumn fx:id="colTipo"          text="Tipo"          prefWidth="100"/>
        <TableColumn fx:id="colCapacidade"    text="Cap. (t)"      prefWidth="80"/>
        <TableColumn fx:id="colCompartimentos" text="Compart."     prefWidth="80"/>
        <TableColumn fx:id="colBandeira"      text="Bandeira"      prefWidth="90"/>
        <TableColumn fx:id="colAno"           text="Ano Fabrico"   prefWidth="90"/>
        <TableColumn fx:id="colEstado"        text="Estado"        prefWidth="110"/>
      </columns>
    </TableView>
  </center>

  <bottom>
    <VBox spacing="6" style="-fx-padding:10;">
      <GridPane hgap="8" vgap="6">
        <Label text="Nome:"           GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="txtNome"   GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="180"/>
        <Label text="Cód. IMO:"       GridPane.rowIndex="0" GridPane.columnIndex="2"/>
        <TextField fx:id="txtImo"    GridPane.rowIndex="0" GridPane.columnIndex="3" prefWidth="120"/>

        <Label text="Tipo:"           GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <ComboBox fx:id="cmbTipo"    GridPane.rowIndex="1" GridPane.columnIndex="1" prefWidth="180"/>
        <Label text="Bandeira:"       GridPane.rowIndex="1" GridPane.columnIndex="2"/>
        <TextField fx:id="txtBandeira" GridPane.rowIndex="1" GridPane.columnIndex="3" prefWidth="120"/>

        <Label text="Cap. máx (t):"   GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="txtCapacidade" GridPane.rowIndex="2" GridPane.columnIndex="1" prefWidth="180"/>
        <Label text="Compartimentos:" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
        <TextField fx:id="txtCompartimentos" GridPane.rowIndex="2" GridPane.columnIndex="3" prefWidth="120"/>

        <Label text="Ano Fabrico:"    GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <TextField fx:id="txtAno"    GridPane.rowIndex="3" GridPane.columnIndex="1" prefWidth="180"/>
      </GridPane>

      <HBox spacing="8">
        <Button text="Adicionar"   onAction="#onAdicionar"/>
        <Button text="Atualizar"   onAction="#onAtualizar"/>
        <Button text="Eliminar"    onAction="#onEliminar"/>
        <Button text="Manutenções" onAction="#onManutencao"/>
      </HBox>
    </VBox>
  </bottom>
</BorderPane>
